# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
/build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
# NOTE: no bare `dist/` here — web/dist (the committed PWA build) must stay tracked.

# Local DB + dumps
*.db
*.db-journal
*.sqlite
*.sqlite3
/data/
/dumps/
# SQLite WAL sidecars
*.db-wal
*.db-shm
# source CSV dumps (Crunchbase exports) dropped at the repo root
/*.csv

# Env / secrets
.env
.env.local
.env.*.local

# Personal, local-only config (real localized outreach template, scratch files).
# The tracked outreach template stays a sanitized example; the real one with
# your credentials lives in local/.
/local/

# Claude Code worktrees (harness-managed checkouts)
.claude/worktrees/

# IDE
.idea/
.vscode/
*.swp
.DS_Store

# PWA source deps + generated public assets (web/ → web/dist/, served as static)
/web/node_modules
/web/public/manifest.webmanifest
/web/public/sw.js
